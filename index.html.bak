1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Manrope';\n  font-style: normal;\n  font-weight: 800;\n  font-display: swap;\n  src: url(\"61c757c6-f6c1-48ee-a863-a03cccc5e408\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n<\u002Fstyle>\n<style>\n  *{box-sizing:border-box}\n  html,body{margin:0;padding:0;background:#F4F2EC}\n  ::selection{background:#2F7D66;color:#fff}\n  @keyframes spin{to{transform:rotate(360deg)}}\n  @keyframes blink{0%,48%{opacity:1}52%,100%{opacity:0}}\n  @keyframes fillbar{0%{width:24%}50%{width:66%}100%{width:24%}}\n  .spin{transform-box:view-box;transform-origin:center;animation:spin 26s linear infinite}\n  @keyframes drawline{from{stroke-dashoffset:3322}to{stroke-dashoffset:0}}\n  @keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}\n  @keyframes fadeOnly{from{opacity:0}to{opacity:1}}\n  .fillbar{animation:fillbar 5s ease-in-out infinite}\n<\u002Fstyle>\n<\u002Fhelmet>\n\n<div id=\"land\" style=\"position:relative;max-width:1600px;margin:0 auto;background:#F4F2EC;font-family:'Manrope',system-ui,sans-serif;color:#16241F;overflow:hidden;\">\n\n  <div id=\"story\" style=\"position:relative;\">\n\n  <!-- ============ CONTINUOUS FILM → LINE → FILM PATH ============ -->\n  <svg viewBox=\"0 0 1600 4200\" preserveAspectRatio=\"none\" style=\"position:absolute;inset:0;width:100%;height:100%;z-index:1;pointer-events:none;overflow:visible;\">\n    <!-- top film rails + sprockets coming out of the big reel -->\n    <g fill=\"none\" stroke=\"#2F7D66\" stroke-linecap=\"round\" stroke-linejoin=\"round\" vector-effect=\"non-scaling-stroke\">\n      <!-- outer rails, converging into the single line at the bottom -->\n      <path d=\"M1304 388 C1305 460 1303 540 1308 660 C1308 745 1318 794 1320 808 C1323 826 1325 834 1326 840\" stroke-width=\"2.2\"><\u002Fpath>\n      <path d=\"M1356 388 C1355 460 1357 540 1352 660 C1352 745 1342 794 1334 808 C1330 826 1327 834 1326 840\" stroke-width=\"2.2\"><\u002Fpath>\n      <!-- frame separators (band between frames) -->\n      <g stroke-width=\"1.4\" opacity=\".55\">\n        <path d=\"M1316 404 L1344 404 M1316 411 L1344 411\"><\u002Fpath><path d=\"M1316 444 L1344 444 M1316 451 L1344 451\"><\u002Fpath><path d=\"M1315 486 L1345 486 M1315 493 L1345 493\"><\u002Fpath><path d=\"M1315 530 L1345 530 M1315 537 L1345 537\"><\u002Fpath><path d=\"M1316 476 L1344 476 M1316 483 L1344 483\"><\u002Fpath><path d=\"M1316 530 L1344 530 M1316 537 L1344 537\"><\u002Fpath><path d=\"M1316 584 L1344 584 M1316 591 L1344 591\"><\u002Fpath><path d=\"M1316 638 L1344 638 M1316 645 L1344 645\"><\u002Fpath><path d=\"M1316 692 L1344 692 M1316 699 L1344 699\"><\u002Fpath><path d=\"M1316 746 L1344 746 M1316 753 L1344 753\"><\u002Fpath>\n      <\u002Fg>\n    <\u002Fg>\n    <!-- sprocket perforations along both edges -->\n    <g fill=\"#2F7D66\" opacity=\".8\">\n      <rect x=\"1309\" y=\"398\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1347\" y=\"398\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1309\" y=\"432\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1347\" y=\"432\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1310\" y=\"468\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1346\" y=\"468\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1311\" y=\"512\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1345\" y=\"512\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1309\" y=\"437\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1347\" y=\"437\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1309\" y=\"464\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1347\" y=\"464\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1309\" y=\"491\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1347\" y=\"491\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1309\" y=\"518\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1347\" y=\"518\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1309\" y=\"545\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1347\" y=\"545\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1309\" y=\"572\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1347\" y=\"572\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1309\" y=\"599\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1347\" y=\"599\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1309\" y=\"626\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1347\" y=\"626\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1309\" y=\"653\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1347\" y=\"653\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1309\" y=\"680\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1347\" y=\"680\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1310\" y=\"707\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1346\" y=\"707\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1312\" y=\"734\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1344\" y=\"734\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect>\n    <\u002Fg>\n\n    <!-- THE single continuous line (scroll-drawn) -->\n    <path id=\"filmline\" fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"3.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" vector-effect=\"non-scaling-stroke\" style=\"stroke-dasharray:3322;animation-name:drawline;animation-duration:auto;animation-timing-function:linear;animation-fill-mode:both;animation-timeline:scroll(root);animation-range:0% 72%;\" d=\"M1326 840 C1327 884 1252 898 1244 948 C1232 1034 1300 1120 1300 1188 C1300 1268 1190 1276 1182 1338 C1174 1408 1300 1486 1304 1566 C1308 1664 1326 1762 1320 1862 C1314 1980 1296 2042 1300 2122 C1304 2242 1186 2362 1182 2452 C1178 2560 1300 2622 1304 2702 C1308 2820 1326 2940 1320 3032 C1314 3160 1296 3222 1300 3302 C1304 3442 1224 3542 1220 3632 C1216 3742 1300 3884 1300 3952\"><\u002Fpath>\n\n    <!-- bottom film: line widens into film, meets the reel's top edge -->\n    <g fill=\"none\" stroke=\"#2F7D66\" stroke-linecap=\"round\" stroke-linejoin=\"round\" vector-effect=\"non-scaling-stroke\" style=\"animation-name:fadeOnly;animation-duration:auto;animation-fill-mode:both;animation-timeline:view();animation-range:entry 0% entry 60%;\">\n      <path d=\"M1300 3952 C1298 3972 1280 3982 1279 4004 C1278 4022 1279 4034 1280 4046\" stroke-width=\"2.2\"><\u002Fpath>\n      <path d=\"M1300 3952 C1302 3972 1320 3982 1321 4004 C1322 4022 1321 4034 1320 4046\" stroke-width=\"2.2\"><\u002Fpath>\n      <g stroke-width=\"1.4\" opacity=\".55\"><path d=\"M1289 4008 L1311 4008 M1289 4015 L1311 4015\"><\u002Fpath><path d=\"M1289 4030 L1311 4030 M1289 4037 L1311 4037\"><\u002Fpath><\u002Fg>\n    <\u002Fg>\n    <g fill=\"#2F7D66\" opacity=\".8\">\n      <rect x=\"1281\" y=\"3990\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1317\" y=\"3990\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1280\" y=\"4022\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><rect x=\"1318\" y=\"4022\" width=\"4.2\" height=\"8\" rx=\"1.3\"><\u002Frect><\u002Fg>\n    \n  <\u002Fsvg>\n\n  <!-- big rotating reel (top) -->\n  <div style=\"position:absolute;left:83.13%;top:5.95%;width:300px;height:300px;transform:translate(-50%,-50%);z-index:3;pointer-events:none;\">\n    <svg viewBox=\"0 0 200 200\" style=\"width:100%;height:100%;overflow:visible;\">\n      <g fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"2.6\"><circle cx=\"100\" cy=\"100\" r=\"93\"><\u002Fcircle><circle cx=\"100\" cy=\"100\" r=\"75\"><\u002Fcircle><\u002Fg>\n      <g class=\"spin\">\n        <g fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"2.4\">\n          <circle cx=\"100\" cy=\"48\" r=\"15\"><\u002Fcircle><circle cx=\"149.5\" cy=\"83.9\" r=\"15\"><\u002Fcircle><circle cx=\"130.6\" cy=\"142.1\" r=\"15\"><\u002Fcircle><circle cx=\"69.4\" cy=\"142.1\" r=\"15\"><\u002Fcircle><circle cx=\"50.5\" cy=\"83.9\" r=\"15\"><\u002Fcircle>\n          <circle cx=\"111.8\" cy=\"83.8\" r=\"7\"><\u002Fcircle><circle cx=\"119\" cy=\"106.2\" r=\"7\"><\u002Fcircle><circle cx=\"100\" cy=\"120\" r=\"7\"><\u002Fcircle><circle cx=\"81\" cy=\"106.2\" r=\"7\"><\u002Fcircle><circle cx=\"88.2\" cy=\"83.8\" r=\"7\"><\u002Fcircle>\n          <circle cx=\"100\" cy=\"100\" r=\"4.5\"><\u002Fcircle>\n        <\u002Fg>\n      <\u002Fg>\n    <\u002Fsvg>\n  <\u002Fdiv>\n\n  <!-- small rotating reel (bottom) -->\n  <div style=\"position:absolute;left:81.25%;top:97.4%;width:150px;height:150px;transform:translate(-50%,-50%);z-index:3;pointer-events:none;animation-name:fadeOnly;animation-duration:auto;animation-fill-mode:both;animation-timeline:view();animation-range:entry 0% entry 55%;\">\n    <svg viewBox=\"0 0 200 200\" style=\"width:100%;height:100%;overflow:visible;\">\n      <g fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"3\"><circle cx=\"100\" cy=\"100\" r=\"93\"><\u002Fcircle><circle cx=\"100\" cy=\"100\" r=\"75\"><\u002Fcircle><\u002Fg>\n      <g class=\"spin\" style=\"animation-duration:18s\">\n        <g fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"3\">\n          <circle cx=\"100\" cy=\"48\" r=\"15\"><\u002Fcircle><circle cx=\"149.5\" cy=\"83.9\" r=\"15\"><\u002Fcircle><circle cx=\"130.6\" cy=\"142.1\" r=\"15\"><\u002Fcircle><circle cx=\"69.4\" cy=\"142.1\" r=\"15\"><\u002Fcircle><circle cx=\"50.5\" cy=\"83.9\" r=\"15\"><\u002Fcircle>\n          <circle cx=\"111.8\" cy=\"83.8\" r=\"7\"><\u002Fcircle><circle cx=\"119\" cy=\"106.2\" r=\"7\"><\u002Fcircle><circle cx=\"100\" cy=\"120\" r=\"7\"><\u002Fcircle><circle cx=\"81\" cy=\"106.2\" r=\"7\"><\u002Fcircle><circle cx=\"88.2\" cy=\"83.8\" r=\"7\"><\u002Fcircle>\n          <circle cx=\"100\" cy=\"100\" r=\"4.5\"><\u002Fcircle>\n        <\u002Fg>\n      <\u002Fg>\n    <\u002Fsvg>\n  <\u002Fdiv>\n\n  <!-- ============ HERO ============ -->\n  <section data-screen-label=\"Hero\" style=\"position:relative;display:flex;min-height:760px;z-index:2;\">\n    <div style=\"width:61%;background:#2F7D66;color:#fff;padding:64px 48px 60px 100px;display:flex;flex-direction:column;justify-content:center;\">\n      <div style=\"display:flex;align-items:center;gap:11px;margin-bottom:54px;\">\n        <svg width=\"26\" height=\"22\" viewBox=\"0 0 26 22\" fill=\"none\" stroke=\"#A6D0BF\" stroke-width=\"1.8\"><rect x=\"1\" y=\"6\" width=\"24\" height=\"15\" rx=\"1.5\"><\u002Frect><path d=\"M1 6 L24 1.5 M7 5 L10 1 M13 4 L16 0.6 M19 3 L22 0\"><\u002Fpath><\u002Fsvg>\n        <span style=\"font-size:13px;font-weight:700;letter-spacing:.2em;color:#A6D0BF;\">PRESS&nbsp;KIT&nbsp;·&nbsp;ЛЕТНЯЯ&nbsp;ПРОГРАММА<\u002Fspan>\n      <\u002Fdiv>\n      <h1 style=\"margin:0;font-size:clamp(30px,3.7vw,58px);line-height:1.03;font-weight:800;letter-spacing:-.024em;\">НЕЙРО-<br>МУЛЬТИПЛИКАЦИОННАЯ<br>СМЕНА<\u002Fh1>\n      <p style=\"margin:32px 0 0;font-size:21px;font-weight:500;color:#D8ECE3;max-width:560px;\">Обнинск · Центр социокультурного проектирования «МАРС» · 24–28 августа<\u002Fp>\n      <div style=\"height:1px;background:rgba(255,255,255,.28);margin:46px 0 36px;max-width:680px;\"><\u002Fdiv>\n      <div style=\"display:flex;gap:56px;flex-wrap:wrap;\">\n        <div><div style=\"font-size:30px;font-weight:800;letter-spacing:-.02em;\">5 дней<\u002Fdiv><div style=\"font-size:14px;font-weight:600;color:#A6D0BF;margin-top:6px;\">от идеи до премьеры<\u002Fdiv><\u002Fdiv>\n        <div><div style=\"font-size:30px;font-weight:800;letter-spacing:-.02em;\">10–11 лет<\u002Fdiv><div style=\"font-size:14px;font-weight:600;color:#A6D0BF;margin-top:6px;\">4–5 класс<\u002Fdiv><\u002Fdiv>\n        <div><div style=\"font-size:30px;font-weight:800;letter-spacing:-.02em;\">ИИ на каждом шаге<\u002Fdiv><div style=\"font-size:14px;font-weight:600;color:#A6D0BF;margin-top:6px;\">сценарий → анимация<\u002Fdiv><\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n    <div style=\"flex:1;position:relative;display:flex;align-items:flex-end;justify-content:center;z-index:4;\">\n      <img src=\"026dda7d-9a97-441e-9ea5-5cce5adc9b87\" alt=\"Юный мультипликатор\" style=\"height:86%;max-width:94%;object-fit:contain;display:block;transform:translateY(150px);filter:drop-shadow(0 24px 40px rgba(20,40,30,.12));\">\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ============ PROGRAM INTRO ============ -->\n  <section data-screen-label=\"Программа\" style=\"position:relative;display:flex;min-height:220px;z-index:2;\">\n    <div style=\"width:56%;padding:54px 56px 40px 100px;display:flex;flex-direction:column;justify-content:center;\">\n      <div style=\"font-size:13px;font-weight:700;letter-spacing:.2em;color:#2F7D66;margin-bottom:14px;\">ПРОГРАММА СМЕНЫ<\u002Fdiv>\n      <h2 style=\"margin:0;font-size:64px;line-height:.95;font-weight:800;letter-spacing:-.03em;\">Пять дней пути<\u002Fh2>\n    <\u002Fdiv>\n    <div style=\"flex:1;\"><\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ============ DAY 1 ============ -->\n  <section data-screen-label=\"День 1\" style=\"position:relative;display:flex;min-height:600px;z-index:2;\">\n    <div style=\"width:56%;flex-shrink:0;background:#DCE6DF;color:#16241F;padding:74px 56px 74px 100px;position:relative;display:flex;flex-direction:column;justify-content:center;\">\n      <div style=\"position:absolute;right:46px;bottom:-6px;font-size:248px;line-height:.74;font-weight:800;color:rgba(47,125,102,.16);letter-spacing:-.04em;pointer-events:none;\">01<\u002Fdiv>\n      <div style=\"font-size:14px;font-weight:700;letter-spacing:.18em;color:#2F7D66;margin-bottom:14px;\">ДЕНЬ 1<\u002Fdiv>\n      <h3 style=\"margin:0 0 22px;font-size:46px;line-height:1.02;font-weight:800;letter-spacing:-.025em;\">Рождение истории<\u002Fh3>\n      <p style=\"margin:0;max-width:520px;font-size:18px;line-height:1.55;font-weight:500;color:#46524C;\">Команды выбирают идею мультфильма и распределяют роли — Сценарист, Художник, Монтажёр. Сценарий и раскадровку пишут вместе с нейросетью GPT-5, а эксперт-мультипликатор объясняет, как устроена история.<\u002Fp>\n    <\u002Fdiv>\n    <div style=\"flex:1;position:relative;display:flex;align-items:flex-end;justify-content:flex-end;perspective:1500px;padding:40px 70px 96px 30px;\">\n      <div style=\"position:absolute;left:7%;right:5%;bottom:64px;height:24px;pointer-events:none;z-index:0;\">\n        <div style=\"position:absolute;left:9%;right:9%;top:20px;height:18px;background:rgba(40,52,46,.13);filter:blur(9px);border-radius:50%;\"><\u002Fdiv>\n        <div style=\"position:absolute;inset:0;background:linear-gradient(180deg,#FCFBF7,#F1EFE8);border-radius:12px;box-shadow:inset 0 1px 0 #ffffff,inset 0 -1px 0 #E4E1D8;border:1px solid #EDEAE1;\"><\u002Fdiv>\n        <div style=\"position:absolute;left:0;right:0;top:100%;height:7px;background:linear-gradient(#E8E5DC,#D9D5CA);border-radius:0 0 12px 12px;\"><\u002Fdiv>\n      <\u002Fdiv>\n      <img src=\"08511ec1-5486-495f-bd4a-df885d6d8fdf\" alt=\"Мальчик печатает на ноутбуке\" style=\"position:absolute;left:-5%;bottom:62px;height:356px;max-width:none;object-fit:contain;z-index:3;pointer-events:none;filter:drop-shadow(0 22px 34px rgba(20,40,30,.12));\">\n      <div style=\"animation-name:fadeUp;animation-duration:auto;animation-timing-function:cubic-bezier(.2,.7,.2,1);animation-fill-mode:both;animation-timeline:view();animation-range:entry 0% entry 38%;position:relative;z-index:1;width:392px;max-width:74%;\">\n        <div style=\"transform:perspective(1500px) rotateY(-16deg);transform-origin:right center;display:flex;flex-direction:column;align-items:center;width:100%;\">\n        <div style=\"width:100%;background:#232E29;border-radius:16px 16px 5px 5px;padding:13px 13px 15px;box-shadow:0 34px 66px -34px rgba(20,40,30,.6);\">\n        <div style=\"background:#fff;border-radius:7px;overflow:hidden;\">\n        <div style=\"display:flex;align-items:center;gap:9px;padding:13px 16px;border-bottom:1px solid #EEF1EE;\">\n          <span style=\"display:flex;gap:5px;\"><i style=\"width:8px;height:8px;border-radius:50%;background:#E7ECE9;display:block;\"><\u002Fi><i style=\"width:8px;height:8px;border-radius:50%;background:#E7ECE9;display:block;\"><\u002Fi><i style=\"width:8px;height:8px;border-radius:50%;background:#E7ECE9;display:block;\"><\u002Fi><\u002Fspan>\n          <span style=\"font:800 13px Manrope;color:#16241F;margin-left:4px;\">GPT-5<\u002Fspan>\n          <span style=\"margin-left:auto;display:flex;align-items:center;gap:5px;font:600 11px Manrope;color:#2F7D66;\"><i style=\"width:6px;height:6px;border-radius:50%;background:#2F7D66;display:block;\"><\u002Fi>online<\u002Fspan>\n        <\u002Fdiv>\n        <div style=\"padding:16px 16px 14px;\">\n          <div style=\"font:700 11px Manrope;letter-spacing:.06em;color:#9AA39E;margin-bottom:14px;\">СОЗДАНИЕ СЦЕНАРИЯ<\u002Fdiv>\n          <div style=\"display:flex;flex-direction:column;gap:12px;\">\n            <div style=\"display:flex;align-items:center;gap:11px;\"><svg width=\"17\" height=\"17\" viewBox=\"0 0 20 20\" fill=\"none\"><circle cx=\"10\" cy=\"10\" r=\"9\" fill=\"#E7F3EE\"><\u002Fcircle><path d=\"M6 10.4 l2.6 2.6 L14 7\" stroke=\"#2F7D66\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><\u002Fpath><\u002Fsvg><span style=\"font:600 13px Manrope;color:#16241F;width:84px;\">Идея<\u002Fspan><span style=\"flex:1;height:6px;border-radius:3px;background:#EDF2EF;\"><\u002Fspan><\u002Fdiv>\n            <div style=\"display:flex;align-items:center;gap:11px;\"><svg width=\"17\" height=\"17\" viewBox=\"0 0 20 20\" fill=\"none\"><circle cx=\"10\" cy=\"10\" r=\"9\" fill=\"#E7F3EE\"><\u002Fcircle><path d=\"M6 10.4 l2.6 2.6 L14 7\" stroke=\"#2F7D66\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><\u002Fpath><\u002Fsvg><span style=\"font:600 13px Manrope;color:#16241F;width:84px;\">Персонажи<\u002Fspan><span style=\"flex:1;height:6px;border-radius:3px;background:#EDF2EF;\"><\u002Fspan><\u002Fdiv>\n            <div style=\"display:flex;align-items:center;gap:11px;\"><svg width=\"17\" height=\"17\" viewBox=\"0 0 20 20\" fill=\"none\"><circle cx=\"10\" cy=\"10\" r=\"9\" fill=\"#E7F3EE\"><\u002Fcircle><path d=\"M6 10.4 l2.6 2.6 L14 7\" stroke=\"#2F7D66\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><\u002Fpath><\u002Fsvg><span style=\"font:600 13px Manrope;color:#16241F;width:84px;\">Сюжет<\u002Fspan><span style=\"flex:1;height:6px;border-radius:3px;background:#EDF2EF;\"><\u002Fspan><\u002Fdiv>\n            <div style=\"display:flex;align-items:center;gap:11px;\"><svg width=\"17\" height=\"17\" viewBox=\"0 0 20 20\" fill=\"none\"><circle cx=\"10\" cy=\"10\" r=\"9\" fill=\"#FBE9E3\"><\u002Fcircle><path d=\"M6 10.4 l2.6 2.6 L14 7\" stroke=\"#CE7E6A\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><\u002Fpath><\u002Fsvg><span style=\"font:600 13px Manrope;color:#16241F;width:84px;\">Диалоги<\u002Fspan><span style=\"flex:1;height:6px;border-radius:3px;background:#EDF2EF;\"><\u002Fspan><\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"display:flex;align-items:center;gap:10px;padding:12px 14px;border-top:1px solid #EEF1EE;\">\n          <span style=\"flex:1;font:500 13px Manrope;color:#8A938E;\">Напишите запрос…<i style=\"display:inline-block;width:1.5px;height:14px;background:#2F7D66;margin-left:2px;vertical-align:-2px;animation:blink 1.1s steps(1) infinite;\"><\u002Fi><\u002Fspan>\n          <span style=\"width:30px;height:30px;border-radius:9px;background:#2F7D66;display:flex;align-items:center;justify-content:center;\"><svg width=\"15\" height=\"15\" viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 8 h9 M8 4 l4 4 -4 4\"><\u002Fpath><\u002Fsvg><\u002Fspan>\n        <\u002Fdiv>\n        <\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"width:128%;background:linear-gradient(#EFF1EE,#D3D7D2);border-radius:3px 3px 13px 13px;padding:9px 13px 7px;transform:perspective(680px) rotateX(56deg);transform-origin:top center;box-shadow:0 20px 30px -16px rgba(20,40,30,.5);\">\n          <div style=\"display:flex;flex-direction:column;gap:4px;\">\n            <div style=\"display:flex;gap:3px;\"><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><\u002Fdiv>\n            <div style=\"display:flex;gap:3px;\"><span style=\"flex:1.4;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1.4;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><\u002Fdiv>\n            <div style=\"display:flex;gap:3px;\"><span style=\"flex:1.8;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1.8;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><\u002Fdiv>\n            <div style=\"display:flex;gap:3px;justify-content:center;\"><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:5;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><span style=\"flex:1;height:8px;border-radius:2px;background:#fff;box-shadow:0 1px 1px rgba(0,0,0,.08);\"><\u002Fspan><\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ============ DAY 2 ============ -->\n  <section data-screen-label=\"День 2\" style=\"position:relative;display:flex;min-height:580px;z-index:2;\">\n    <div style=\"width:56%;flex-shrink:0;background:#F8DDD8;color:#16241F;padding:74px 56px 74px 100px;position:relative;display:flex;flex-direction:column;justify-content:center;\">\n      <div style=\"position:absolute;right:46px;bottom:-6px;font-size:248px;line-height:.74;font-weight:800;color:rgba(206,126,106,.24);letter-spacing:-.04em;pointer-events:none;\">02<\u002Fdiv>\n      <div style=\"font-size:14px;font-weight:700;letter-spacing:.18em;color:#C2604A;margin-bottom:14px;\">ДЕНЬ 2<\u002Fdiv>\n      <h3 style=\"margin:0 0 22px;font-size:46px;line-height:1.02;font-weight:800;letter-spacing:-.025em;\">Лица на экране<\u002Fh3>\n      <p style=\"margin:0;max-width:520px;font-size:18px;line-height:1.55;font-weight:500;color:#6E5A54;\">История обретает героев. Команды придумывают персонажей и создают их в нейросети Nano Banana 2, расставляют по кадрам раскадровки. В этот же день — знакомство с 3D-печатью.<\u002Fp>\n    <\u002Fdiv>\n    <div style=\"flex:1;position:relative;display:flex;align-items:flex-end;justify-content:flex-end;perspective:1500px;padding:40px 32px 124px 30px;\">\n      <img src=\"312d6189-6e3c-4137-9a5a-cee01a20b16f\" alt=\"Мальчик рисует стилусом на планшете\" style=\"position:absolute;left:7%;bottom:74px;height:318px;max-width:none;object-fit:contain;z-index:3;pointer-events:none;filter:drop-shadow(0 22px 34px rgba(20,40,30,.12));\">\n      <div style=\"position:absolute;left:5%;right:4%;bottom:64px;height:24px;pointer-events:none;z-index:0;\">\n        <div style=\"position:absolute;left:9%;right:9%;top:20px;height:18px;background:rgba(40,52,46,.13);filter:blur(9px);border-radius:50%;\"><\u002Fdiv>\n        <div style=\"position:absolute;inset:0;background:linear-gradient(180deg,#FCFBF7,#F1EFE8);border-radius:12px;box-shadow:inset 0 1px 0 #ffffff,inset 0 -1px 0 #E4E1D8;border:1px solid #EDEAE1;\"><\u002Fdiv>\n        <div style=\"position:absolute;left:0;right:0;top:100%;height:7px;background:linear-gradient(#E8E5DC,#D9D5CA);border-radius:0 0 12px 12px;\"><\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"animation-name:fadeUp;animation-duration:auto;animation-timing-function:cubic-bezier(.2,.7,.2,1);animation-fill-mode:both;animation-timeline:view();animation-range:entry 0% entry 38%;position:relative;z-index:1;width:238px;max-width:60%;\">\n        <div style=\"position:relative;background:#2A2622;border-radius:22px;padding:15px 13px;box-shadow:0 30px 62px -32px rgba(20,40,30,.55);transform:perspective(1400px) rotateY(-23deg) rotateX(7deg);transform-origin:center center;\">\n        <div style=\"background:#fff;border-radius:11px;overflow:hidden;\">\n        <div style=\"display:flex;align-items:center;padding:13px 16px;border-bottom:1px solid #EEF1EE;\">\n          <span style=\"font:800 13px Manrope;color:#16241F;\">Nano Banana 2<\u002Fspan>\n          <span style=\"margin-left:auto;color:#C4CBC7;font-size:15px;\">×<\u002Fspan>\n        <\u002Fdiv>\n        <div style=\"padding:14px 16px 16px;\">\n          <div style=\"font:700 11px Manrope;letter-spacing:.06em;color:#9AA39E;margin-bottom:12px;\">ГЕНЕРАЦИЯ ПЕРСОНАЖА<\u002Fdiv>\n          <div style=\"height:118px;border-radius:10px;background:#F2F6F4;display:flex;align-items:center;justify-content:center;font:600 12px Manrope;color:#AEB7B2;\">персонаж<\u002Fdiv>\n          <div style=\"margin:13px 0 12px;font:500 12px Manrope;color:#6E7670;\"><span style=\"color:#9AA39E;\">Промпт:<\u002Fspan> зелёный герой…<i style=\"display:inline-block;width:1.5px;height:12px;background:#CE7E6A;margin-left:2px;vertical-align:-1px;animation:blink 1.1s steps(1) infinite;\"><\u002Fi><\u002Fdiv>\n          <div style=\"height:34px;border-radius:9px;background:#CE7E6A;color:#fff;display:flex;align-items:center;justify-content:center;font:700 13px Manrope;\">Сгенерировать<\u002Fdiv>\n        <\u002Fdiv>\n        <\u002Fdiv>\n        <span style=\"position:absolute;top:50%;left:5px;transform:translateY(-50%);width:4px;height:4px;border-radius:50%;background:#4A453F;\"><\u002Fspan>\n        <div style=\"position:absolute;right:-15px;top:30px;width:7px;height:122px;background:linear-gradient(#CBD1CB,#9FA7A0);border-radius:4px;transform:rotate(9deg);box-shadow:0 5px 12px -5px rgba(0,0,0,.35);\"><div style=\"position:absolute;bottom:-8px;left:0;width:0;height:0;border-left:3.5px solid transparent;border-right:3.5px solid transparent;border-top:8px solid #7E867F;\"><\u002Fdiv><\u002Fdiv>\n        <!-- simple back kickstand legs (two angled edges) -->\n        <div style=\"position:absolute;left:40%;bottom:-44px;width:8px;height:60px;background:linear-gradient(#D2CEC5,#ABA79D);border-radius:5px;transform:rotate(25deg);transform-origin:top center;box-shadow:0 5px 11px -6px rgba(0,0,0,.35);z-index:-1;\"><\u002Fdiv>\n        <div style=\"position:absolute;right:34%;bottom:-44px;width:8px;height:60px;background:linear-gradient(#D2CEC5,#ABA79D);border-radius:5px;transform:rotate(-25deg);transform-origin:top center;box-shadow:0 5px 11px -6px rgba(0,0,0,.35);z-index:-1;\"><\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ============ DAY 3 ============ -->\n  <section data-screen-label=\"День 3\" style=\"position:relative;display:flex;min-height:580px;z-index:2;\">\n    <div style=\"width:56%;flex-shrink:0;background:#F6E8CB;color:#2A1A06;padding:74px 56px 74px 100px;position:relative;display:flex;flex-direction:column;justify-content:center;\">\n      <div style=\"position:absolute;right:46px;bottom:-6px;font-size:248px;line-height:.74;font-weight:800;color:rgba(42,26,6,.10);letter-spacing:-.04em;pointer-events:none;\">03<\u002Fdiv>\n      <div style=\"font-size:14px;font-weight:700;letter-spacing:.18em;color:#9A7430;margin-bottom:14px;\">ДЕНЬ 3<\u002Fdiv>\n      <h3 style=\"margin:0 0 22px;font-size:46px;line-height:1.02;font-weight:800;letter-spacing:-.025em;\">Голос и музыка<\u002Fh3>\n      <p style=\"margin:0;max-width:520px;font-size:18px;line-height:1.55;font-weight:500;color:#5A4836;\">Персонажи начинают звучать: команды записывают голоса через ElevenLabs, сочиняют музыку в Suno, а сцены оживляют в Kling и Google&nbsp;Veo. Самый «звучащий» день смены.<\u002Fp>\n    <\u002Fdiv>\n    <div style=\"flex:1;position:relative;display:flex;align-items:flex-end;justify-content:flex-end;perspective:1500px;padding:40px 44px 96px 30px;\">\n      <div style=\"position:absolute;left:5%;right:4%;bottom:64px;height:24px;pointer-events:none;z-index:0;\">\n        <div style=\"position:absolute;left:9%;right:9%;top:20px;height:18px;background:rgba(40,52,46,.13);filter:blur(9px);border-radius:50%;\"><\u002Fdiv>\n        <div style=\"position:absolute;inset:0;background:linear-gradient(180deg,#FCFBF7,#F1EFE8);border-radius:12px;box-shadow:inset 0 1px 0 #ffffff,inset 0 -1px 0 #E4E1D8;border:1px solid #EDEAE1;\"><\u002Fdiv>\n        <div style=\"position:absolute;left:0;right:0;top:100%;height:7px;background:linear-gradient(#E8E5DC,#D9D5CA);border-radius:0 0 12px 12px;\"><\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"animation-name:fadeUp;animation-duration:auto;animation-timing-function:cubic-bezier(.2,.7,.2,1);animation-fill-mode:both;animation-timeline:view();animation-range:entry 0% entry 38%;position:relative;z-index:1;width:338px;max-width:58%;\">\n        <div style=\"transform:perspective(1500px) rotateY(-16deg);transform-origin:right center;display:flex;flex-direction:column;align-items:center;width:100%;\">\n        <div style=\"width:100%;background:#232E29;border-radius:15px 15px 4px 4px;padding:12px;box-shadow:0 32px 64px -34px rgba(20,40,30,.6);\">\n        <div style=\"background:#EEF2EF;border-radius:7px;padding:12px;display:flex;flex-direction:column;gap:12px;\">\n        <div style=\"background:#fff;border:1.5px solid #E2E8E4;border-radius:14px;padding:13px 15px;\">\n          <div style=\"display:flex;align-items:center;gap:9px;margin-bottom:11px;\"><span style=\"font:800 13px Manrope;color:#16241F;\">ElevenLabs<\u002Fspan><span style=\"margin-left:auto;font:600 11px Manrope;color:#9AA39E;\">Генерация голоса<\u002Fspan><\u002Fdiv>\n          <div style=\"display:flex;align-items:center;gap:10px;\"><span style=\"width:26px;height:26px;border-radius:50%;background:#2F7D66;display:flex;align-items:center;justify-content:center;\"><svg width=\"9\" height=\"10\" viewBox=\"0 0 9 10\" fill=\"#fff\"><path d=\"M0 0 L9 5 L0 10 Z\"><\u002Fpath><\u002Fsvg><\u002Fspan><span style=\"flex:1;height:5px;border-radius:3px;background:#EDF2EF;position:relative;overflow:hidden;\"><span class=\"fillbar\" style=\"position:absolute;left:0;top:0;height:100%;background:#2F7D66;border-radius:3px;\"><\u002Fspan><\u002Fspan><span style=\"font:600 11px Manrope;color:#6E7670;\">0:42<\u002Fspan><\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"background:#fff;border:1.5px solid #E2E8E4;border-radius:14px;padding:13px 15px;\">\n          <div style=\"display:flex;align-items:center;gap:9px;margin-bottom:11px;\"><span style=\"font:800 13px Manrope;color:#16241F;\">Suno<\u002Fspan><span style=\"margin-left:auto;font:600 11px Manrope;color:#9AA39E;\">Создание музыки<\u002Fspan><\u002Fdiv>\n          <div style=\"display:flex;align-items:center;gap:10px;\"><span style=\"width:26px;height:26px;border-radius:50%;background:#CE7E6A;display:flex;align-items:center;justify-content:center;\"><svg width=\"9\" height=\"10\" viewBox=\"0 0 9 10\" fill=\"#fff\"><path d=\"M0 0 L9 5 L0 10 Z\"><\u002Fpath><\u002Fsvg><\u002Fspan><span style=\"flex:1;height:5px;border-radius:3px;background:#EDF2EF;position:relative;overflow:hidden;\"><span class=\"fillbar\" style=\"position:absolute;left:0;top:0;height:100%;background:#CE7E6A;border-radius:3px;animation-delay:1.2s;\"><\u002Fspan><\u002Fspan><span style=\"font:600 11px Manrope;color:#6E7670;\">1:40<\u002Fspan><\u002Fdiv>\n        <\u002Fdiv>\n        <\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"width:116%;height:13px;background:linear-gradient(#E2E7E3,#C2C8C3);border-radius:0 0 13px 13px;\"><\u002Fdiv>\n        <div style=\"width:78px;height:4px;background:#AEB5B0;border-radius:0 0 5px 5px;\"><\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <img src=\"ff69d022-fa75-441e-8b34-d841b3365331\" alt=\"Мальчик с микрофоном озвучивает мультфильм\" style=\"position:absolute;left:1%;bottom:62px;height:392px;max-width:none;object-fit:contain;z-index:2;pointer-events:none;filter:drop-shadow(0 22px 34px rgba(20,40,30,.12));\">\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ============ DAY 4 ============ -->\n  <section data-screen-label=\"День 4\" style=\"position:relative;display:flex;min-height:580px;z-index:2;\">\n    <div style=\"width:56%;flex-shrink:0;background:#D6E2DE;color:#16241F;padding:74px 56px 74px 100px;position:relative;display:flex;flex-direction:column;justify-content:center;\">\n      <div style=\"position:absolute;right:46px;bottom:-6px;font-size:248px;line-height:.74;font-weight:800;color:rgba(60,107,98,.16);letter-spacing:-.04em;pointer-events:none;\">04<\u002Fdiv>\n      <div style=\"font-size:14px;font-weight:700;letter-spacing:.18em;color:#3C6B62;margin-bottom:14px;\">ДЕНЬ 4<\u002Fdiv>\n      <h3 style=\"margin:0 0 22px;font-size:46px;line-height:1.02;font-weight:800;letter-spacing:-.025em;\">Сборка фильма<\u002Fh3>\n      <p style=\"margin:0;max-width:520px;font-size:18px;line-height:1.55;font-weight:500;color:#46524E;\">Монтажёры собирают видео и звук в единый мультфильм в Kling и Google&nbsp;Veo. Параллельно команда делает сайт своей студии в конструкторе Tilda и готовит презентацию.<\u002Fp>\n    <\u002Fdiv>\n    <div style=\"flex:1;position:relative;display:flex;align-items:flex-end;justify-content:flex-end;gap:0;perspective:1500px;padding:40px 60px 96px 30px;\">\n      <img src=\"97699dd4-6ae0-42fa-bd2b-f2f07aa868be\" alt=\"Мальчик смотрит, как создаётся видео\" style=\"position:absolute;left:2%;bottom:64px;height:352px;max-width:none;object-fit:contain;z-index:2;pointer-events:none;filter:drop-shadow(0 22px 34px rgba(20,40,30,.12));\">\n      <div style=\"position:absolute;left:5%;right:4%;bottom:64px;height:24px;pointer-events:none;z-index:0;\">\n        <div style=\"position:absolute;left:9%;right:9%;top:20px;height:18px;background:rgba(40,52,46,.13);filter:blur(9px);border-radius:50%;\"><\u002Fdiv>\n        <div style=\"position:absolute;inset:0;background:linear-gradient(180deg,#FCFBF7,#F1EFE8);border-radius:12px;box-shadow:inset 0 1px 0 #ffffff,inset 0 -1px 0 #E4E1D8;border:1px solid #EDEAE1;\"><\u002Fdiv>\n        <div style=\"position:absolute;left:0;right:0;top:100%;height:7px;background:linear-gradient(#E8E5DC,#D9D5CA);border-radius:0 0 12px 12px;\"><\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"animation-name:fadeUp;animation-duration:auto;animation-timing-function:cubic-bezier(.2,.7,.2,1);animation-fill-mode:both;animation-timeline:view();animation-range:entry 0% entry 38%;position:relative;z-index:1;width:330px;max-width:55%;\">\n        <div style=\"transform:perspective(1500px) rotateY(-21deg);transform-origin:right center;display:flex;flex-direction:column;align-items:center;width:100%;\">\n        <div style=\"width:100%;background:#232E29;border-radius:12px;padding:11px;box-shadow:0 32px 64px -34px rgba(20,40,30,.6);\">\n        <div style=\"background:#fff;border-radius:6px;overflow:hidden;\">\n        <div style=\"display:flex;align-items:center;padding:12px 15px;border-bottom:1px solid #EEF1EE;\"><span style=\"font:800 12.5px Manrope;color:#16241F;\">Kling / Google Veo<\u002Fspan><span style=\"margin-left:auto;color:#C4CBC7;font-size:15px;\">×<\u002Fspan><\u002Fdiv>\n        <div style=\"padding:13px 15px 15px;\">\n          <div style=\"height:96px;border-radius:9px;background:#F2F6F4;display:flex;align-items:center;justify-content:center;font:600 11px Manrope;color:#AEB7B2;margin-bottom:13px;position:relative;\"><span style=\"position:absolute;left:10px;top:9px;font:700 10px Manrope;color:#2F7D66;\">PREVIEW<\u002Fspan><svg width=\"26\" height=\"26\" viewBox=\"0 0 26 26\" fill=\"none\"><circle cx=\"13\" cy=\"13\" r=\"12\" fill=\"#2F7D66\"><\u002Fcircle><path d=\"M10 8 L18 13 L10 18 Z\" fill=\"#fff\"><\u002Fpath><\u002Fsvg><\u002Fdiv>\n          <div style=\"font:700 10px Manrope;letter-spacing:.06em;color:#9AA39E;margin-bottom:8px;\">ТАЙМЛАЙН<\u002Fdiv>\n          <div style=\"display:flex;gap:4px;margin-bottom:9px;\"><span style=\"height:18px;flex:2;border-radius:3px;background:#E7F3EE;\"><\u002Fspan><span style=\"height:18px;flex:1.3;border-radius:3px;background:#FBE9E3;\"><\u002Fspan><span style=\"height:18px;flex:2.4;border-radius:3px;background:#E7F3EE;\"><\u002Fspan><span style=\"height:18px;flex:1;border-radius:3px;background:#FCEFD4;\"><\u002Fspan><\u002Fdiv>\n          <div style=\"height:5px;border-radius:3px;background:#EDF2EF;position:relative;overflow:hidden;\"><span class=\"fillbar\" style=\"position:absolute;left:0;top:0;height:100%;background:#3C6B62;border-radius:3px;\"><\u002Fspan><\u002Fdiv>\n        <\u002Fdiv>\n        <\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"width:22px;height:17px;background:linear-gradient(#D2D8D3,#B7BDB8);\"><\u002Fdiv>\n        <div style=\"width:100px;height:7px;background:#B2B9B4;border-radius:3px;\"><\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"animation-name:fadeUp;animation-duration:auto;animation-timing-function:cubic-bezier(.2,.7,.2,1);animation-fill-mode:both;animation-timeline:view();animation-range:entry 0% entry 38%;align-self:flex-start;margin:18px 0 0 -86px;width:134px;position:relative;z-index:2;\">\n        <div style=\"background:#fff;border:1.5px solid #E2E8E4;border-radius:13px;overflow:hidden;box-shadow:0 24px 46px -22px rgba(20,40,30,.42);transform:perspective(1400px) rotateY(-15deg);transform-origin:right center;\">\n        <div style=\"display:flex;align-items:center;gap:5px;padding:9px 11px;border-bottom:1px solid #EEF1EE;\"><i style=\"width:6px;height:6px;border-radius:50%;background:#E7ECE9;display:block;\"><\u002Fi><i style=\"width:6px;height:6px;border-radius:50%;background:#E7ECE9;display:block;\"><\u002Fi><span style=\"margin-left:auto;font:700 9px Manrope;color:#9AA39E;\">Tilda<\u002Fspan><\u002Fdiv>\n        <div style=\"padding:11px;\">\n          <div style=\"height:9px;width:70%;border-radius:3px;background:#16241F;margin-bottom:8px;\"><\u002Fdiv>\n          <div style=\"height:38px;border-radius:6px;background:#F2F6F4;margin-bottom:8px;\"><\u002Fdiv>\n          <div style=\"display:flex;gap:6px;\"><span style=\"height:22px;flex:1;border-radius:5px;background:#E7F3EE;\"><\u002Fspan><span style=\"height:22px;flex:1;border-radius:5px;background:#FBE9E3;\"><\u002Fspan><\u002Fdiv>\n          <div style=\"margin-top:9px;font:600 10px Manrope;color:#9AA39E;text-align:center;\">Создание сайта<\u002Fdiv>\n        <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ============ DAY 5 ============ -->\n  <section data-screen-label=\"День 5\" style=\"position:relative;display:flex;min-height:620px;z-index:2;\">\n    <div style=\"width:56%;flex-shrink:0;background:#DCEAE0;color:#16241F;padding:74px 56px 74px 100px;position:relative;overflow:hidden;display:flex;flex-direction:column;justify-content:center;\">\n      <div style=\"position:absolute;right:46px;bottom:-6px;font-size:248px;line-height:.74;font-weight:800;color:rgba(47,125,102,.16);letter-spacing:-.04em;pointer-events:none;\">05<\u002Fdiv>\n      <div style=\"font-size:14px;font-weight:700;letter-spacing:.18em;color:#2F7D66;margin-bottom:14px;\">ДЕНЬ 5<\u002Fdiv>\n      <h3 style=\"margin:0 0 22px;font-size:46px;line-height:1.02;font-weight:800;letter-spacing:-.025em;\">Премьера<\u002Fh3>\n      <p style=\"margin:0;max-width:520px;font-size:18px;line-height:1.55;font-weight:500;color:#46524C;\">Финальная репетиция — и показ. Каждая команда представляет свой мультфильм и сайт студии, рассказывает, как шла работа. В конце — сертификаты участников.<\u002Fp>\n    <\u002Fdiv>\n    <div style=\"flex:1;position:relative;display:flex;flex-direction:column;align-items:flex-end;justify-content:center;gap:16px;perspective:1500px;padding:40px 78px 92px 30px;\">\n      <img src=\"3dad9776-8bd9-4500-8531-d3e576908dc6\" alt=\"Ведущий указывает на экран с мультфильмом\" style=\"position:absolute;left:2%;bottom:60px;height:466px;max-width:none;object-fit:contain;z-index:2;pointer-events:none;filter:drop-shadow(0 22px 34px rgba(20,40,30,.12));\">\n      <div style=\"position:absolute;left:8%;right:4%;bottom:58px;height:24px;pointer-events:none;z-index:0;\">\n        <div style=\"position:absolute;left:9%;right:9%;top:20px;height:18px;background:rgba(40,52,46,.13);filter:blur(9px);border-radius:50%;\"><\u002Fdiv>\n        <div style=\"position:absolute;inset:0;background:linear-gradient(180deg,#FCFBF7,#F1EFE8);border-radius:12px;box-shadow:inset 0 1px 0 #ffffff,inset 0 -1px 0 #E4E1D8;border:1px solid #EDEAE1;\"><\u002Fdiv>\n        <div style=\"position:absolute;left:0;right:0;top:100%;height:7px;background:linear-gradient(#E8E5DC,#D9D5CA);border-radius:0 0 12px 12px;\"><\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"animation-name:fadeUp;animation-duration:auto;animation-timing-function:cubic-bezier(.2,.7,.2,1);animation-fill-mode:both;animation-timeline:view();animation-range:entry 0% entry 38%;width:330px;max-width:66%;position:relative;z-index:1;\">\n        <div style=\"transform:perspective(1700px) rotateY(-8deg);transform-origin:right center;\">\n        <div style=\"border-radius:12px;padding:11px;background:#232E29;box-shadow:0 30px 60px -32px rgba(20,40,30,.55);\">\n          <div style=\"height:170px;border-radius:7px;background:#F2F6F4;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;\">\n            <img src=\"5cf7f94a-f09f-46ee-aa29-1132d6a8fbea\" alt=\"Кадр мультфильма — космонавт\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 42%;\">\n            <span style=\"position:absolute;left:11px;top:9px;font:700 10px Manrope;color:#2F7D66;letter-spacing:.04em;z-index:1;\">МУЛЬТФИЛЬМ<\u002Fspan>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"width:2px;height:18px;background:#16241F;margin:0 auto;\"><\u002Fdiv>\n        <div style=\"width:120px;height:8px;border-radius:4px;background:#16241F;margin:0 auto;\"><\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"animation-name:fadeUp;animation-duration:auto;animation-timing-function:cubic-bezier(.2,.7,.2,1);animation-fill-mode:both;animation-timeline:view();animation-range:entry 0% entry 38%;display:flex;align-items:flex-end;gap:9px;\">\n        <span style=\"width:34px;height:26px;border-radius:8px 8px 3px 3px;background:rgba(27,140,104,.28);\"><\u002Fspan>\n        <span style=\"width:34px;height:32px;border-radius:8px 8px 3px 3px;background:rgba(27,140,104,.40);\"><\u002Fspan>\n        <span style=\"width:34px;height:26px;border-radius:8px 8px 3px 3px;background:rgba(27,140,104,.28);\"><\u002Fspan>\n        <span style=\"width:34px;height:32px;border-radius:8px 8px 3px 3px;background:rgba(27,140,104,.40);\"><\u002Fspan>\n        <span style=\"width:34px;height:26px;border-radius:8px 8px 3px 3px;background:rgba(27,140,104,.28);\"><\u002Fspan>\n      <\u002Fdiv>\n      <div style=\"animation-name:fadeUp;animation-duration:auto;animation-timing-function:cubic-bezier(.2,.7,.2,1);animation-fill-mode:both;animation-timeline:view();animation-range:entry 0% entry 38%;font:600 12px Manrope;color:#6E7670;\">зрители · показывает мультфильм<\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ============ CLOSING ============ -->\n  <section data-screen-label=\"Финал\" style=\"position:relative;min-height:260px;z-index:2;display:flex;align-items:center;\">\n    <div style=\"padding:40px 56px 40px 100px;max-width:56%;\">\n      <div style=\"font-size:13px;font-weight:700;letter-spacing:.2em;color:#2F7D66;margin-bottom:12px;\">ИТОГ<\u002Fdiv>\n      <p style=\"margin:0;font-size:26px;line-height:1.3;font-weight:700;letter-spacing:-.02em;color:#16241F;max-width:560px;\">Полный цикл — от катушки идей до премьеры — за пять дней.<\u002Fp>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <\u002Fdiv><!-- /story -->\n\n  <!-- ============ TOOLS ============ -->\n  <section data-screen-label=\"Арсенал\" style=\"position:relative;background:#F4F2EC;overflow:hidden;padding-bottom:30px;z-index:2;\">\n    <div style=\"position:absolute;top:0;left:0;bottom:0;width:64px;display:flex;flex-direction:column;align-items:center;gap:34px;padding-top:34px;\">\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"#9FC2B3\" stroke-width=\"1.6\"><circle cx=\"10\" cy=\"10\" r=\"8.5\"><\u002Fcircle><\u002Fsvg>\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"#9FC2B3\" stroke-width=\"1.6\"><circle cx=\"10\" cy=\"10\" r=\"8.5\"><\u002Fcircle><\u002Fsvg>\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"#9FC2B3\" stroke-width=\"1.6\"><circle cx=\"10\" cy=\"10\" r=\"8.5\"><\u002Fcircle><\u002Fsvg>\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"#9FC2B3\" stroke-width=\"1.6\"><circle cx=\"10\" cy=\"10\" r=\"8.5\"><\u002Fcircle><\u002Fsvg>\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"#9FC2B3\" stroke-width=\"1.6\"><circle cx=\"10\" cy=\"10\" r=\"8.5\"><\u002Fcircle><\u002Fsvg>\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"#9FC2B3\" stroke-width=\"1.6\"><circle cx=\"10\" cy=\"10\" r=\"8.5\"><\u002Fcircle><\u002Fsvg>\n    <\u002Fdiv>\n    <svg viewBox=\"0 0 220 220\" style=\"position:absolute;top:240px;left:42%;width:300px;height:300px;opacity:.06;pointer-events:none;\" fill=\"none\" stroke=\"#16241F\" stroke-width=\"3\" stroke-linejoin=\"round\"><path d=\"M110 20 L190 64 L190 156 L110 200 L30 156 L30 64 Z M110 20 L110 110 M110 110 L190 64 M110 110 L30 64\"><\u002Fpath><\u002Fsvg>\n    <div style=\"padding:70px 40px 0 100px;position:relative;z-index:2;max-width:920px;\">\n      <div style=\"font-size:13px;font-weight:700;letter-spacing:.2em;color:#2F7D66;margin-bottom:14px;\">АРСЕНАЛ<\u002Fdiv>\n      <h2 style=\"margin:0 0 44px;font-size:60px;line-height:.98;font-weight:800;letter-spacing:-.03em;\">Инструменты<br>студии<\u002Fh2>\n      <div>\n        <div style=\"display:grid;grid-template-columns:34px 200px 1fr;align-items:center;gap:22px;padding:22px 0;border-top:1px solid #DAD7CD;\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 22 22\" fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"1.7\" stroke-linecap=\"round\"><path d=\"M11 1 L11 21 M1 11 L21 11 M4 4 L18 18 M18 4 L4 18\"><\u002Fpath><\u002Fsvg><div style=\"font-size:21px;font-weight:700;\">GPT-5<\u002Fdiv><div style=\"font-size:17px;font-weight:500;color:#7C8079;\">Сценарий и раскадровка<\u002Fdiv><\u002Fdiv>\n        <div style=\"display:grid;grid-template-columns:34px 200px 1fr;align-items:center;gap:22px;padding:22px 0;border-top:1px solid #DAD7CD;\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 22 22\" fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"1.7\" stroke-linecap=\"round\"><path d=\"M3 19 L5 13 L16 2 L20 6 L9 17 Z M14 4 L18 8\"><\u002Fpath><\u002Fsvg><div style=\"font-size:21px;font-weight:700;\">Nano Banana 2<\u002Fdiv><div style=\"font-size:17px;font-weight:500;color:#7C8079;\">Создание персонажей<\u002Fdiv><\u002Fdiv>\n        <div style=\"display:grid;grid-template-columns:34px 200px 1fr;align-items:center;gap:22px;padding:22px 0;border-top:1px solid #DAD7CD;\"><svg width=\"20\" height=\"22\" viewBox=\"0 0 20 22\" fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"1.7\" stroke-linecap=\"round\"><rect x=\"6\" y=\"1\" width=\"8\" height=\"13\" rx=\"4\"><\u002Frect><path d=\"M3 10 a7 7 0 0 0 14 0 M10 17 L10 21 M6 21 L14 21\"><\u002Fpath><\u002Fsvg><div style=\"font-size:21px;font-weight:700;\">ElevenLabs<\u002Fdiv><div style=\"font-size:17px;font-weight:500;color:#7C8079;\">Озвучка персонажей<\u002Fdiv><\u002Fdiv>\n        <div style=\"display:grid;grid-template-columns:34px 200px 1fr;align-items:center;gap:22px;padding:22px 0;border-top:1px solid #DAD7CD;\"><svg width=\"20\" height=\"22\" viewBox=\"0 0 20 22\" fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"1.7\" stroke-linecap=\"round\"><path d=\"M6 19 L6 5 L17 2 L17 15\"><\u002Fpath><circle cx=\"4\" cy=\"19\" r=\"2.4\"><\u002Fcircle><circle cx=\"15\" cy=\"15\" r=\"2.4\"><\u002Fcircle><\u002Fsvg><div style=\"font-size:21px;font-weight:700;\">Suno<\u002Fdiv><div style=\"font-size:17px;font-weight:500;color:#7C8079;\">Музыка для фильма<\u002Fdiv><\u002Fdiv>\n        <div style=\"display:grid;grid-template-columns:34px 200px 1fr;align-items:center;gap:22px;padding:22px 0;border-top:1px solid #DAD7CD;\"><svg width=\"30\" height=\"18\" viewBox=\"0 0 30 18\" fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"1.7\"><rect x=\"1\" y=\"1\" width=\"8\" height=\"16\" rx=\"1.3\"><\u002Frect><rect x=\"11\" y=\"1\" width=\"8\" height=\"16\" rx=\"1.3\"><\u002Frect><rect x=\"21\" y=\"1\" width=\"8\" height=\"16\" rx=\"1.3\"><\u002Frect><\u002Fsvg><div style=\"font-size:21px;font-weight:700;\">Kling / Veo<\u002Fdiv><div style=\"font-size:17px;font-weight:500;color:#7C8079;\">Анимация сцен<\u002Fdiv><\u002Fdiv>\n        <div style=\"display:grid;grid-template-columns:34px 200px 1fr;align-items:center;gap:22px;padding:22px 0;border-top:1px solid #DAD7CD;border-bottom:1px solid #DAD7CD;\"><svg width=\"22\" height=\"20\" viewBox=\"0 0 22 20\" fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"1.7\"><rect x=\"1\" y=\"1\" width=\"20\" height=\"18\" rx=\"2\"><\u002Frect><path d=\"M1 6 L21 6\"><\u002Fpath><\u002Fsvg><div style=\"font-size:21px;font-weight:700;\">Tilda<\u002Fdiv><div style=\"font-size:17px;font-weight:500;color:#7C8079;\">Сайт студии — конструктор, без ИИ<\u002Fdiv><\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ============ TEAM ============ -->\n  <section data-screen-label=\"Команда\" style=\"position:relative;background:#F4F2EC;overflow:hidden;padding-bottom:84px;z-index:2;\">\n    <div style=\"position:absolute;top:0;left:0;bottom:0;width:64px;display:flex;flex-direction:column;align-items:center;gap:34px;padding-top:34px;\">\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"#9FC2B3\" stroke-width=\"1.6\"><circle cx=\"10\" cy=\"10\" r=\"8.5\"><\u002Fcircle><\u002Fsvg>\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"#9FC2B3\" stroke-width=\"1.6\"><circle cx=\"10\" cy=\"10\" r=\"8.5\"><\u002Fcircle><\u002Fsvg>\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"#9FC2B3\" stroke-width=\"1.6\"><circle cx=\"10\" cy=\"10\" r=\"8.5\"><\u002Fcircle><\u002Fsvg>\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"#9FC2B3\" stroke-width=\"1.6\"><circle cx=\"10\" cy=\"10\" r=\"8.5\"><\u002Fcircle><\u002Fsvg>\n      <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" stroke=\"#9FC2B3\" stroke-width=\"1.6\"><circle cx=\"10\" cy=\"10\" r=\"8.5\"><\u002Fcircle><\u002Fsvg>\n    <\u002Fdiv>\n    <div style=\"padding:60px 40px 0 100px;position:relative;z-index:2;max-width:880px;\">\n      <div style=\"font-size:13px;font-weight:700;letter-spacing:.2em;color:#2F7D66;margin-bottom:14px;\">КОМАНДА СМЕНЫ<\u002Fdiv>\n      <h2 style=\"margin:0 0 50px;font-size:60px;line-height:.98;font-weight:800;letter-spacing:-.03em;\">Кто рядом с<br>ребёнком<\u002Fh2>\n\n      <div style=\"display:flex;gap:30px;padding:34px 0;border-top:1px solid #DAD7CD;\">\n        <div style=\"flex:none;width:56px;height:56px;border-radius:50%;background:#E3F1EA;display:flex;align-items:center;justify-content:center;\"><svg width=\"26\" height=\"26\" viewBox=\"0 0 26 26\" fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"1.6\"><circle cx=\"13\" cy=\"13\" r=\"11\"><\u002Fcircle><circle cx=\"13\" cy=\"9\" r=\"2.4\"><\u002Fcircle><circle cx=\"10\" cy=\"16\" r=\"2.4\"><\u002Fcircle><circle cx=\"16\" cy=\"16\" r=\"2.4\"><\u002Fcircle><\u002Fsvg><\u002Fdiv>\n        <div><h4 style=\"margin:0 0 12px;font-size:24px;font-weight:700;\">Модераторы команд<\u002Fh4><p style=\"margin:0 0 14px;font-size:18px;line-height:1.55;font-weight:500;color:#33473F;max-width:560px;\">Реальные победители конкурса фонда АТР АЭС «Территория успеха: МультиКЛИПация» — три года подряд.<\u002Fp><div style=\"font-size:16px;font-weight:700;color:#2F7D66;\">2024 — 2 место&nbsp;&nbsp;·&nbsp;&nbsp;2025 — 1 место&nbsp;&nbsp;·&nbsp;&nbsp;2026 — 1 место<\u002Fdiv><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div style=\"display:flex;gap:30px;padding:34px 0;border-top:1px solid #DAD7CD;\">\n        <div style=\"flex:none;width:56px;height:56px;border-radius:50%;background:#E3F1EA;display:flex;align-items:center;justify-content:center;\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"1.7\" stroke-linecap=\"round\"><path d=\"M12 2 L12 22 M2 12 L22 12 M5 5 L19 19 M19 5 L5 19\"><\u002Fpath><\u002Fsvg><\u002Fdiv>\n        <div><h4 style=\"margin:0 0 12px;font-size:24px;font-weight:700;\">Специалист по нейросетям<\u002Fh4><p style=\"margin:0 0 18px;font-size:18px;line-height:1.55;font-weight:500;color:#33473F;max-width:560px;\"><strong style=\"font-weight:700;color:#16241F;\">Назукина Анастасия Александровна.<\u002Fstrong> Повышение квалификации в Московской школе управления «СКОЛКОВО» — программа «Онлайн-интенсив по разработке ИИ-продуктов», 27 часов.<\u002Fp>\n        <div style=\"display:flex;align-items:flex-end;gap:14px;\"><div style=\"width:96px;height:128px;background:repeating-linear-gradient(135deg,#E8E5DC,#E8E5DC 7px,#F0EDE4 7px,#F0EDE4 14px);border:1px solid #D7D3C8;border-radius:3px;transform:rotate(-4deg);box-shadow:0 6px 18px rgba(0,0,0,.07);\"><\u002Fdiv><span style=\"font-size:14px;font-weight:600;color:#9A9589;\">Удостоверение №0048580<\u002Fspan><\u002Fdiv><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div style=\"display:flex;gap:30px;padding:34px 0;border-top:1px solid #DAD7CD;border-bottom:1px solid #DAD7CD;\">\n        <div style=\"flex:none;width:56px;height:56px;border-radius:50%;background:#E3F1EA;display:flex;align-items:center;justify-content:center;\"><svg width=\"26\" height=\"26\" viewBox=\"0 0 26 26\" fill=\"none\" stroke=\"#2F7D66\" stroke-width=\"1.6\"><rect x=\"3\" y=\"5\" width=\"20\" height=\"14\" rx=\"1.6\"><\u002Frect><path d=\"M9 23 L17 23 M13 19 L13 23\"><\u002Fpath><\u002Fsvg><\u002Fdiv>\n        <div><h4 style=\"margin:0 0 12px;font-size:24px;font-weight:700;\">Ведущий смены<\u002Fh4><p style=\"margin:0 0 14px;font-size:18px;line-height:1.55;font-weight:500;color:#33473F;max-width:560px;\"><strong style=\"font-weight:700;color:#16241F;\">Власов Артемий Дмитриевич.<\u002Fstrong> Год практической работы с нейросетями: Claude, Claude Cowork, Claude Code, Gemini, ChatGPT, NotebookLM и другие инструменты Google.<\u002Fp><p style=\"margin:0 0 16px;font-size:18px;line-height:1.55;font-weight:500;color:#33473F;max-width:560px;\">Автор AI-продукта <strong style=\"font-weight:700;color:#16241F;\">FlashCast<\u002Fstrong> — платформы аудио-подкастов, где нейросеть сама находит, пересказывает и озвучивает новости без участия человека в публикации.<\u002Fp><a href=\"#\" style=\"font-size:17px;font-weight:700;color:#CE7E6A;text-decoration:none;border-bottom:1.5px solid #CE7E6A;padding-bottom:2px;\">Открыть FlashCast →<\u002Fa><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div style=\"margin-top:40px;font-size:13px;font-weight:700;letter-spacing:.18em;color:#9A9589;\">НЕЙРО-МУЛЬТИПЛИКАЦИОННАЯ СМЕНА<\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n<\u002Fdiv>\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\" data-props=\"{&quot;$preview&quot;:{&quot;width&quot;:1600,&quot;height&quot;:900}}\">\nclass Component extends DCLogic {\n  renderVals(){ return {}; }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
</body>
</html>